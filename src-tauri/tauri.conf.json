{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VideoCaptor",
  "version": "0.2.2",
  "identifier": "com.eos.videocaptor",
  "build": {
    "beforeDevCommand": "npm run prepare:ffmpeg && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run prepare:ffmpeg && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; media-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$DOWNLOAD/**", "$VIDEO/**", "$DOCUMENT/**", "$DESKTOP/**", "$APPCACHE/**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../presets/**/*": "presets",
      "resources/ffmpeg": "ffmpeg"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
